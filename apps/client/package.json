{
  "name": "@kudeploy/client",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite dev --port 3000\" \"gql-gen --watch\"",
    "dev:e2e": "vite dev --mode e2e --host 127.0.0.1 --port 3100",
    "codegen": "graphql-codegen",
    "build": "vite build",
    "serve": "vite preview",
    "test": "vitest run --exclude \"e2e/**\" --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "node e2e/utils/report-coverage.mjs",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint --fix",
    "format": "prettier --write . && eslint --fix",
    "i18next:extract": "i18next-cli extract",
    "i18next:status": "i18next-cli status",
    "i18next:sync": "i18next-cli sync"
  },
