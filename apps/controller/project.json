{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "controller",
  "root": "apps/controller",
  "projectType": "application",
  "tags": ["type:controller", "type:docker-image", "language:go"],
  "release": {
    "version": {
      "versionActions": "./apps/controller/scripts/version-file.cjs"
    },
    "docker": {
      "versionSchemes": {
        "production": "{versionActionsVersion}"
      },
      "repositoryName": "kudeploy/controller",
      "registryUrl": "ghcr.io"
    }
  },
  "targets": {
    "docker:build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/controller",
        "command": "docker build --tag apps-controller ."
      },
      "inputs": ["production", "^production"],
      "cache": true
    },
    "docker:run": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/controller",
        "command": "docker run {args} apps-controller"
      },
      "dependsOn": ["docker:build"],
      "inputs": ["production", "^production"],
      "cache": false
    },
    "nx-release-publish": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "node apps/controller/scripts/publish-image.cjs \"{args.dryRun}\""
      },
      "dependsOn": [],
      "cache": false
    }
  }
}
