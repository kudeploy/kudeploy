{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "client-helm-chart",
  "root": "helm-charts/kudeploy-client",
  "projectType": "application",
  "tags": ["type:helm-chart"],
  "metadata": {
    "description": "Kudeploy web client."
  },
  "release": {
    "version": {
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk",
      "versionActions": "nx-helm/release"
    }
  },
  "implicitDependencies": ["client"],
  "targets": {
    "dependency-build": {
      "executor": "nx-helm:dependency-build",
      "options": {
        "chartRoot": "helm-charts/kudeploy-client",
        "distDir": "dist"
      },
      "cache": false,
      "inputs": ["default", "{workspaceRoot}/pnpm-lock.yaml"],
      "dependsOn": [
        { "dependencies": true, "target": "package", "params": "ignore" }
      ]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "helm lint helm-charts/kudeploy-client"
      },
      "cache": true,
      "inputs": ["default", "^default", "{workspaceRoot}/pnpm-lock.yaml"],
      "dependsOn": ["dependency-build"]
    },
    "package": {
      "executor": "nx-helm:package",
      "options": {
        "chartRoot": "helm-charts/kudeploy-client",
        "distDir": "dist",
        "repository": "oci://ghcr.io/kudeploy/helm-charts"
      },
      "cache": true,
      "inputs": ["default", "^default", "{workspaceRoot}/pnpm-lock.yaml"],
      "outputs": ["{workspaceRoot}/dist/kudeploy-client-*.tgz"],
      "dependsOn": [
        { "dependencies": true, "target": "package", "params": "ignore" },
        "dependency-build"
      ]
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "helm push dist/kudeploy-client-*.tgz oci://ghcr.io/kudeploy/helm-charts"
      },
      "cache": false,
      "dependsOn": ["package"]
    },
    "nx-release-publish": {
      "executor": "nx-helm:release-publish",
      "options": {
        "chartName": "kudeploy-client",
        "chartRoot": "helm-charts/kudeploy-client",
        "distDir": "dist",
        "repository": "oci://ghcr.io/kudeploy/helm-charts"
      },
      "cache": false,
      "dependsOn": ["lint", "package"]
    }
  }
}
