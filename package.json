{
  "name": "@kudeploy/workspace",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "version-packages": "changeset version && node scripts/sync-chart-versions.mjs && helm dependency update charts/kudeploy-controller && helm dependency update charts/kudeploy",
    "publish-packages": "node scripts/publish-packages.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "prettier": "^3.7.4",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": "24.x"
  }
}
