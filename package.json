{
  "name": "@kudeploy/workspace",
  "private": true,
  "scripts": {
    "build": "nx run-many -t build --exclude @kudeploy/workspace",
    "dev": "nx run-many -t dev --exclude @kudeploy/workspace",
    "lint": "nx run-many -t lint --exclude @kudeploy/workspace",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "nx run-many -t check-types --exclude @kudeploy/workspace",
    "commitlint": "commitlint --last --verbose",
    "release": "nx release --skip-publish",
    "release:publish": "nx release publish --yes"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@nx/docker": "^22.7.5",
    "@nx/js": "^22.7.5",
    "nx": "^22.7.5",
    "nx-helm": "^0.1.1",
    "prettier": "^3.7.4",
    "yaml": "^2.9.0"
  },
  "nx": {
    "name": "@kudeploy/workspace"
  },
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": "24.x"
  }
}
